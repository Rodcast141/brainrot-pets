<!DOCTYPE html>
<html>
<head>
    <title>Brainrot Pets: Official Release</title>
    <script src="https://aframe.io/releases/1.6.0/aframe.min.js"></script>
    <script src="https://unpkg.com/aframe-environment-component@1.3.7/dist/aframe-environment-component.min.js"></script>
</head>
<body style="margin: 0; overflow: hidden;">
    <a-scene vr-mode-ui="enabled: true">
        
        <a-assets>
            <a-asset-item id="pug" src="https://cdn.aframe.io/examples/ar/models/pug/pug.glb"></a-asset-item>
            <a-asset-item id="cat" src="https://cdn.aframe.io/examples/ar/models/triceratops/triceratops.glb"></a-asset-item>
        </a-assets>

        <a-entity id="rig" position="0 0.1 0" gorilla-move vr-controls>
            <a-camera id="camera" look-controls position="0 1.6 0">
                <a-entity position="0 0.25 -0.6" scale="0.07 0.07 0.07">
                    <a-plane width="8" height="4" color="#ff00ff" opacity="0.9"></a-plane>
                    <a-text id="bucks-display" value="BUCKS: 0" color="#00ff00" align="center" position="0 1 0.01" width="15"></a-text>
                    <a-text value="ACTIVE PET: FOLLOW MODE" color="white" align="center" position="0 -0.5 0.01" width="8"></a-text>
                </a-entity>
            </a-camera>

            <a-entity id="active-pet" position="0.8 0 -0.8" rotation="0 180 0" scale="0.2 0.2 0.2" gltf-model="#pug" 
                      animation="property: position; dir: alternate; dur: 2000; loop: true; to: 0.8 0.2 -0.8">
            </a-entity>

            <a-entity id="leftHand" oculus-touch-controls="hand: left" laser-controls="hand: left" raycaster="objects: .clickable; far: 5"></a-entity>
