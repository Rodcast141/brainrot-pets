<!DOCTYPE html>
<html>
<head>
    <title>Brainrot Animals: Pro Edition</title>
    <link rel="manifest" href="site.webmanifest" crossorigin="use-credentials">
    <script src="https://aframe.io/releases/1.6.0/aframe.min.js"></script>
    <script src="https://unpkg.com/aframe-environment-component@1.3.7/dist/aframe-environment-component.min.js"></script>
</head>
<body style="margin: 0; overflow: hidden;">
    <a-scene vr-mode-ui="enabled: true" cursor="rayOrigin: mouse" raycaster="objects: .clickable">
        
        <a-assets>
            <a-asset-item id="pug-model" src="https://cdn.aframe.io/examples/ar/models/pug/pug.glb"></a-asset-item>
        </a-assets>

        <a-entity id="rig" position="0 0.1 0" gorilla-move vr-turn-controls>
            <a-camera id="camera" look-controls position="0 1.6 0">
                <a-entity id="hud" position="0 0.2 -0.5" scale="0.08 0.08 0.08">
                    <a-plane width="6" height="4.5" color="#ff00ff" opacity="0.8"></a-plane>
                    <a-text value="BRAINROT ANIMALS" color="yellow" align="center" position="0 1.5 0.01" width="12"></a-text>
                    <a-text id="bucks-display" value="BUCKS: 0" color="#00ff00" align="center" position="0 0.5 0.01" width="10"></a-text>
                    <a-text value="L-Stick: Smooth Turn | R-Stick: Snap Turn" color="white" align="center" position="0 -0.5 0.01" width="5"></a-text>
                </a-entity>

                <a-entity id="my-pug" gltf-model="#pug-model" position="0.4 -0.5 -0.6" rotation="0 180 0" scale="0.15 0.15 0.15"></a-entity>
            </a-camera
